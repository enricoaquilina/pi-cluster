#!/bin/bash
# Pre-push validation: syntax-check changed playbooks and shell scripts.
# Runs only on files changed vs the tracking remote — fast (~2-3s).
set -o pipefail

failed=0

# Find what changed vs the remote tracking branch
upstream=$(git rev-parse --abbrev-ref '@{upstream}' 2>/dev/null) || upstream="origin/master"
changed_files=$(git diff --name-only "$upstream"...HEAD 2>/dev/null) || changed_files=""

if [ -z "$changed_files" ]; then
    exit 0
fi

# --- Push policy: require PR for critical paths pushed to master ---
pushing_to_master=0
while read -r _local_ref _local_sha _remote_ref _remote_sha; do
    case "$_remote_ref" in
        refs/heads/master|refs/heads/main) pushing_to_master=1 ;;
    esac
done

if [ "$pushing_to_master" -eq 1 ] && [ -n "$changed_files" ]; then
    PR_REQUIRED_PATTERNS=(
        '^mission-control/backend/'
        '^playbooks/'
        '^\.github/workflows/'
        'docker-compose.*\.yml$'
        '^hooks/'
        '^\.pre-commit-config\.yaml$'
    )

    blocked=0
    blocked_reason=""

    for pattern in "${PR_REQUIRED_PATTERNS[@]}"; do
        match=$(echo "$changed_files" | grep -E "$pattern" | head -1)
        if [ -n "$match" ]; then
            blocked=1
            blocked_reason="$match matches policy pattern"
            break
        fi
    done

    file_count=$(echo "$changed_files" | grep -c '.' || echo 0)
    if [ "$file_count" -ge 4 ] && [ "$blocked" -eq 0 ]; then
        blocked=1
        blocked_reason="$file_count files changed (≥4 requires PR)"
    fi

    if [ "$blocked" -eq 1 ]; then
        echo ""
        echo "pre-push: BLOCKED — direct push to master not allowed."
        echo "  Reason: $blocked_reason"
        echo "  Create a branch: git checkout -b fix/description"
        echo "  Override: git push --no-verify (use sparingly)"
        exit 1
    fi
fi

# Ansible playbook syntax check
playbooks=$(echo "$changed_files" | grep '^playbooks/.*\.yml$' || true)
if [ -n "$playbooks" ]; then
    echo "pre-push: checking Ansible playbooks..."
    for pb in $playbooks; do
        if [ -f "$pb" ]; then
            if ! ansible-playbook --syntax-check -i tests/inventory.yml "$pb" >/dev/null 2>&1; then
                echo "  FAIL: $pb"
                failed=1
            else
                echo "  OK: $pb"
            fi
        fi
    done
fi

# Shell script syntax check (skip bats test files — @test is not bash syntax)
scripts=$(echo "$changed_files" | grep '\.sh$' || true)
if [ -n "$scripts" ]; then
    echo "pre-push: checking shell scripts..."
    for s in $scripts; do
        if [ -f "$s" ]; then
            if head -1 "$s" | grep -q 'bats$'; then
                echo "  SKIP (bats): $s"
                continue
            fi
            if ! bash -n "$s" 2>/dev/null; then
                echo "  FAIL: $s"
                failed=1
            else
                echo "  OK: $s"
            fi
        fi
    done
fi

# Docker compose validation
compose_files=$(echo "$changed_files" | grep 'docker-compose.*\.yml$' || true)
if [ -n "$compose_files" ]; then
    echo "pre-push: checking docker-compose files..."
    for f in $compose_files; do
        if [ -f "$f" ]; then
            if ! docker compose -f "$f" config --quiet 2>/dev/null; then
                echo "  FAIL: $f"
                failed=1
            else
                echo "  OK: $f"
            fi
        fi
    done
fi

if [ "$failed" -ne 0 ]; then
    echo ""
    echo "pre-push: validation failed. Fix errors before pushing."
    exit 1
fi
