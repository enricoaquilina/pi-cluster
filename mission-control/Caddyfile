{
	servers {
		timeouts {
			read_body 10s
			read_header 5s
			idle 120s
		}
	}
}

:80 {
	header {
		X-Request-ID {http.request.uuid}
	}

	handle /api/events {
		reverse_proxy api:8000 {
			header_up X-Api-Key {$API_KEY}
			header_up X-Request-ID {http.request.uuid}
			flush_interval -1
			transport http {
				dial_timeout 10s
			}
		}
	}

	handle /api/* {
		request_body {
			max_size 1MB
		}
		reverse_proxy api:8000 {
			header_up X-Api-Key {$API_KEY}
			header_up X-Request-ID {http.request.uuid}
			transport http {
				dial_timeout 10s
			}
		}
	}

	handle /health {
		reverse_proxy api:8000 {
			header_up X-Request-ID {http.request.uuid}
			transport http {
				dial_timeout 10s
			}
		}
	}

	handle /trading/* {
		root * /srv/frontend
		try_files {path} /trading/index.html
		file_server
		header *.js Cache-Control "no-cache, must-revalidate"
	}

	handle /trading {
		redir /trading/ permanent
	}

	handle {
		root * /srv/frontend
		try_files {path} /index.html
		file_server
	}
}
