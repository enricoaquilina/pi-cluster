{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "CPU Usage by Node",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "targets": [
        {
          "expr": "100 - (avg by(node) (rate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "{{node}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "fillOpacity": 15, "lineWidth": 2 }
        }
      }
    },
    {
      "title": "Memory Usage by Node",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "targets": [
        {
          "expr": "(1 - node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes) * 100",
          "legendFormat": "{{node}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "fillOpacity": 15, "lineWidth": 2 }
        }
      }
    },
    {
      "title": "Disk Usage",
      "type": "gauge",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "targets": [
        {
          "expr": "100 - (node_filesystem_avail_bytes{mountpoint=~\"/|/mnt/data|/mnt/external\",fstype!=\"tmpfs\"} / node_filesystem_size_bytes * 100)",
          "legendFormat": "{{node}} {{mountpoint}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "title": "CPU Temperature",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "targets": [
        {
          "expr": "node_hwmon_temp_celsius",
          "legendFormat": "{{node}} {{chip}} {{sensor}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "custom": { "fillOpacity": 10, "lineWidth": 2 },
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 85 }
            ]
          }
        }
      }
    },
    {
      "title": "Network Traffic",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{device=~\"eth0|enp.*\"}[5m]) * 8",
          "legendFormat": "{{node}} rx"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{device=~\"eth0|enp.*\"}[5m]) * 8",
          "legendFormat": "{{node}} tx"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bps",
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    },
    {
      "title": "System Load (1m)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "P4169E866C3094E38" },
      "targets": [
        {
          "expr": "node_load1",
          "legendFormat": "{{node}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        }
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["pi-cluster"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "30s",
  "timepicker": {},
  "timezone": "Europe/Malta",
  "title": "Pi Cluster Overview",
  "uid": "pi-cluster-overview"
}
