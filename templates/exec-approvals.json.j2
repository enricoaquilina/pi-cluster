{
  "version": 1,
  "socket": {
    "path": "/home/enrico/.openclaw/exec-approvals.sock",
    "token": "{{ openclaw_exec_approvals_token | default('auto-approve') }}"
  },
  "defaults": {
    "security": "full",
    "ask": "off",
    "autoAllowSkills": true
  },
  "agents": {
    "main": {
      "security": "full",
      "ask": "off",
      "allowlist": [
        {
          "pattern": "**",
          "id": "auto-allow-all"
        }
      ]
    },
    "*": {
      "security": "full",
      "ask": "off",
      "allowlist": [
        {
          "pattern": "**",
          "id": "auto-allow-wildcard"
        }
      ]
    }
  }
}
