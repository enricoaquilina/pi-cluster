# Keepalived configuration for Pi-hole HA
# Role: {{ keepalived_state }} | Priority: {{ keepalived_priority }}
# Managed by Ansible - do not edit manually

global_defs {
    router_id PIHOLE_{{ inventory_hostname }}
    script_user root
    enable_script_security
}

vrrp_script check_pihole {
    script "/usr/local/bin/check-pihole.sh"
    interval 5
    weight -60
    fall 3
    rise 2
}

vrrp_instance PIHOLE_VIP {
    state {{ keepalived_state }}
    interface eth0
    virtual_router_id 53
    priority {{ keepalived_priority }}
    advert_int 1

    unicast_src_ip {{ keepalived_unicast_ip }}
    unicast_peer {
{% for host in groups['pihole'] | difference([inventory_hostname]) %}
        {{ hostvars[host].keepalived_unicast_ip }}
{% endfor %}
    }

    authentication {
        auth_type PASS
        auth_pass {{ keepalived_auth_pass }}
    }

    virtual_ipaddress {
        {{ pihole_vip }}/24 dev eth0
    }

    track_script {
        check_pihole
    }

    notify_master "/usr/local/bin/keepalived-notify.sh MASTER"
    notify_backup "/usr/local/bin/keepalived-notify.sh BACKUP"
    notify_fault  "/usr/local/bin/keepalived-notify.sh FAULT"
}
