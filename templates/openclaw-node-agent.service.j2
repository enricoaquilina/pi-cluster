[Unit]
Description=OpenClaw Node Stats Agent
After=network-online.target

[Service]
Type=oneshot
User=enrico
Environment=OPENCLAW_NODE_NAME={{ openclaw_node_name }}
Environment=OPENCLAW_MASTER_URL=http://{{ openclaw_gateway_host }}:8520
Environment=NODE_PUSH_SECRET={{ node_push_secret }}
ExecStart=/usr/bin/python3 {{ openclaw_agent_script | default(openclaw_workspace + '/scripts/openclaw-node-agent.py') }}
